{
  "expo": {
    "name": "GoBuyMe",
    "slug": "gobuyme",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "gobuyme",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-notifications",
        {
          "color": "#FF521B",
          "sounds": []
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "GoBuyMe needs your location to show nearby vendors and track deliveries.",
          "locationWhenInUsePermission": "GoBuyMe needs your location to show nearby vendors and track deliveries."
        }
      ],
      [
        "expo-secure-store",
        {
          "faceIDPermission": "GoBuyMe uses Face ID to keep your account secure."
        }
      ]
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "dev.bubblebarrel.gobuyme",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "GoBuyMe needs your location to show nearby vendors and track deliveries.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "GoBuyMe needs your location to track your deliveries."
      },
      "runtimeVersion": {
        "policy": "appVersion"
      }
    },
    "android": {
      "package": "dev.bubblebarrel.gobuyme",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FF521B"
      },
      "statusBar": {
        "translucent": true,
        "backgroundColor": "#00000000"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "FOREGROUND_SERVICE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "FOREGROUND_SERVICE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "runtimeVersion": "1.0.0"
    },
    "web": {
      "bundler": "metro"
    },
    "experiments": {
      "typedRoutes": true
    },
    "newArchEnabled": false,
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "79f18436-58d9-4282-bbd3-b5b12030b803"
      }
    },
    "owner": "8037674195",
    "updates": {
      "url": "https://u.expo.dev/79f18436-58d9-4282-bbd3-b5b12030b803"
    }
  }
}
